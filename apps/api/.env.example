# Backend FastAPI
NDI_API_PREFIX=/api
NDI_ENVIRONMENT=local

# CORS
NDI_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001"]

# Stockage local
NDI_DATA_DIR=data
NDI_DUCKDB_FILENAME=ndi.duckdb

# Vector store (Qdrant) — docker compose up -d qdrant
NDI_QDRANT_URL=http://localhost:6333
NDI_QDRANT_COLLECTION=schema_index

# LLM — Ollama local sur Mac (le backend ajoute /v1 automatiquement si besoin)
NDI_LLM_BASE_URL=http://localhost:11434
NDI_LLM_API_KEY=ollama
NDI_LLM_MODEL=qwen3.6:35b
NDI_VISION_MODEL=qwen3.6:35b                  # Optional: model for image analysis
NDI_INDEXING_LLM_MODEL=qwen3.6:35b                  # Optional: separate model for indexing
NDI_LLM_CONTEXT_LENGTH=65536

# Embeddings — Ollama expose aussi /v1/embeddings
NDI_EMBEDDING_BASE_URL=http://localhost:11434
NDI_EMBEDDING_API_KEY=ollama
NDI_EMBEDDING_MODEL=bge-m3:latest
NDI_RETRIEVAL_TOP_K=6

# API auth — conseillé à false en local
NDI_AUTH_ENABLED=false


# Agent Prompts Configuration (AGENTS.md + SKILL.md)
NDI_AGENTS_BASE_DIR=agents
