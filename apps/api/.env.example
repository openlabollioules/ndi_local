# Backend FastAPI
NDI_API_PREFIX=/api
NDI_ENVIRONMENT=local

# CORS
NDI_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Stockage local
NDI_DATA_DIR=data
NDI_DUCKDB_FILENAME=ndi.duckdb

# Vector store (Qdrant) — docker-compose up -d qdrant
NDI_QDRANT_URL=http://localhost:6333
NDI_QDRANT_COLLECTION=schema_index

# LLM — vLLM / OpenAI-compatible API
NDI_LLM_BASE_URL=http://localhost:8001/v1
NDI_LLM_API_KEY=EMPTY
NDI_LLM_MODEL=qwen3:14b
NDI_VISION_MODEL=                        # Optional: model for image analysis (e.g. qwen2.5-vl)
NDI_INDEXING_LLM_MODEL=                  # Optional: separate model for indexing
NDI_LLM_CONTEXT_LENGTH=65536

# Embeddings — OpenAI-compatible /v1/embeddings
NDI_EMBEDDING_BASE_URL=http://localhost:8002/v1
NDI_EMBEDDING_API_KEY=EMPTY
NDI_EMBEDDING_MODEL=bge-m3
NDI_RETRIEVAL_TOP_K=6


# Agent Prompts Configuration (AGENTS.md + SKILL.md)
NDI_AGENTS_BASE_DIR=agents
